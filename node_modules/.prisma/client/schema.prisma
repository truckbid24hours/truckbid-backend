generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  BOTH
  ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  AUCTION_SCHEDULED
  AUCTION_LIVE
  SOLD
  UNSOLD
  CANCELLED
}

enum AuctionStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum EmdStatus {
  HELD
  REFUNDED
  FORFEITED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  FORFEITED
}

model User {
  id           String        @id @default(uuid())
  fullName     String
  phone        String        @unique
  email        String        @unique
  passwordHash String
  role         UserRole      @default(BUYER)
  kycStatus    KycStatus     @default(PENDING)
  kycDocuments String[]
  aadhaarEnc   String?
  panEnc       String?
  isSuspended  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  listings     Listing[]
  bids         Bid[]
  emds         Emd[]
  buyerTxns    Transaction[] @relation("BuyerTxns")
}

model Listing {
  id              String        @id @default(uuid())
  sellerId        String
  seller          User          @relation(fields: [sellerId], references: [id])
  title           String
  make            String
  model           String
  year            Int
  kmDriven        Int
  location        String
  basePrice       Float
  description     String
  photos          String[]
  rcDocument      String?
  listingFeePaid  Boolean       @default(false)
  listingFeeTxnId String?
  status          ListingStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  auction         Auction?
}

model Auction {
  id              String        @id @default(uuid())
  listingId       String        @unique
  listing         Listing       @relation(fields: [listingId], references: [id])
  scheduledStart  DateTime
  scheduledEnd    DateTime
  actualStart     DateTime?
  actualEnd       DateTime?
  status          AuctionStatus @default(SCHEDULED)
  reserveMet      Boolean       @default(false)
  winningBidId    String?
  winningBidderId String?
  finalPrice      Float?
  extensionCount  Int           @default(0)
  createdAt       DateTime      @default(now())
  bids            Bid[]
  emds            Emd[]
  transaction     Transaction?
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])
  bidderId  String
  bidder    User     @relation(fields: [bidderId], references: [id])
  amount    Float
  isWinning Boolean  @default(false)
  timestamp DateTime @default(now())
}

model Emd {
  id            String    @id @default(uuid())
  auctionId     String
  auction       Auction   @relation(fields: [auctionId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  amount        Float
  razorpayPayId String
  status        EmdStatus @default(HELD)
  depositedAt   DateTime  @default(now())
  refundedAt    DateTime?
  forfeitedAt   DateTime?
}

model Transaction {
  id              String        @id @default(uuid())
  auctionId       String        @unique
  auction         Auction       @relation(fields: [auctionId], references: [id])
  buyerId         String
  buyer           User          @relation("BuyerTxns", fields: [buyerId], references: [id])
  finalPrice      Float
  buyerFee        Float
  sellerFee       Float
  platformRevenue Float
  paymentStatus   PaymentStatus @default(PENDING)
  paymentDeadline DateTime
  razorpayOrderId String?
  createdAt       DateTime      @default(now())
}
